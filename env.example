import { useState } from 'react'
import { useQuery, useMutation, useQueryClient } from '@tanstack/react-query'
import { useStore } from '@/store/useStore'
import { api } from '@/api/client'
import { Card, CardTitle, Btn, StatBox } from '@/components/ui'
import { getAvatarColor, copyToClipboard } from '@/utils'

export default function Profile() {
  const { tgUser, showToast } = useStore()
  const userId = tgUser?.id
  const qc = useQueryClient()

  const [bio, setBio] = useState('')
  const [bioSaved, setBioSaved] = useState(false)
  const [weeklyReport, setWeeklyReport] = useState<string | null>(null)
  const [loadingReport, setLoadingReport] = useState(false)

  const { data: user } = useQuery({
    queryKey: ['user', userId],
    queryFn: async () => {
      const u = await api.users.get(userId!)
      if (u.bio && !bioSaved) setBio(u.bio)
      return u
    },
    enabled: !!userId,
  })

  const { data: ref } = useQuery({
    queryKey: ['referral', userId],
    queryFn: () => api.referral.get(userId!),
    enabled: !!userId,
  })

  const bioMutation = useMutation({
    mutationFn: () => api.users.updateBio(userId!, bio),
    onSuccess: () => {
      setBioSaved(true)
      qc.invalidateQueries({ queryKey: ['user', userId] })
      showToast('✓ Описание сохранено!')
    },
  })

  const handleWeeklyReport = async () => {
    setLoadingReport(true)
    try {
      if (userId) {
        const data = await api.ai.weeklyInsight(userId)
        setWeeklyReport(data.text)
      } else {
        setWeeklyReport('Данных пока мало. Трекай ещё несколько дней — и я покажу реальные паттерны.')
      }
    } catch {
      setWeeklyReport('Не удалось загрузить отчёт. Попробуй позже.')
    } finally {
      setLoadingReport(false)
    }
  }

  const handleCopyRef = async () => {
    if (!ref) return
    const ok = await copyToClipboard(ref.bot_link)
    showToast(ok ? '✓ Ссылка скопирована!' : `Код: ${ref.referral_code}`)
  }

  const name = tgUser?.first_name ?? 'Пользователь'
  const username = tgUser?.username ? `@${tgUser.username}` : 'без username'
  const initials = name[0]?.toUpperCase() ?? 'А'
  const avatarColor = getAvatarColor(userId ?? 0)
  const sub = user?.subscription ?? 'free'
  const subLabels = { free: '🌿 Free', base: '🔵 Base', pro: '⭐ Pro' }
  const subColors = {
    free: { bg: 'var(--green-light)', color: 'var(--green-dark)' },
    base: { bg: 'var(--blue-light)', color: 'var(--blue)' },
    pro: { bg: 'var(--gold-light)', color: '#7a5200' },
  }

  const daysInApp = user?.created_at
    ? Math.max(1, Math.floor((Date.now() - new Date(user.created_at).getTime()) / 86_400_000))
    : '—'

  return (
    <div className="pt-[22px] page-enter">
      {/* Header */}
      <div className="flex items-center gap-[14px] mb-[16px]">
        <div
          className="w-[64px] h-[64px] rounded-full flex items-center justify-center font-serif text-[24px] font-bold text-white flex-shrink-0"
          style={{ background: avatarColor, boxShadow: '0 4px 16px rgba(45,74,43,.25)' }}
        >
          {initials}
        </div>
        <div className="flex-1 min-w-0">
          <div className="font-serif text-[20px] font-bold text-green-dark truncate">{name}</div>
          <div className="text-[13px] text-txt-2 mt-[2px]">{username}</div>
          <div
            className="mt-[6px] inline-flex items-center gap-[5px] px-[10px] py-[3px] rounded-full text-[11px] font-semibold"
            style={subColors[sub]}
          >
            {subLabels[sub]}
          </div>
        </div>
      </div>

      {/* Bio */}
      <Card>
        <CardTitle>✏️ О себе</CardTitle>
        <textarea
          value={bio}
          onChange={e => { setBio(e.target.value); setBioSaved(false) }}
          rows={3}
          placeholder="Пару слов о себе: цели, что трекаешь, почему начал..."
          className="w-full bg-bg-2 border-[1.5px] border-transparent focus:border-green focus:bg-white rounded-[11px] p-[12px] text-[13px] outline-none resize-none transition-colors mb-[10px]"
        />
        <Btn onClick={() => bioMutation.mutate()} variant="secondary" className="!w-auto !py-[8px] !px-[16px] !text-[13px]" disabled={bioMutation.isPending}>
          {bioMutation.isPending ? 'Сохраняю...' : bioSaved ? '✓ Сохранено' : 'Сохранить'}
        </Btn>
      </Card>

      {/* Stats */}
      <div className="grid grid-cols-2 gap-[10px] mb-[11px]">
        <StatBox icon="📅" value={String(daysInApp)} label="дней в трекере" />
        <StatBox icon="🔗" value={String(ref?.invited_count ?? 0)} label="рефералов" />
      </div>

      {/* Reports */}
      <Card>
        <CardTitle>📊 Отчёты</CardTitle>
        <div className="flex flex-col gap-[10px]">
          {/* Weekly AI */}
          <div className="flex items-center justify-between p-[12px] bg-bg-2 rounded-[12px]">
            <div>
              <div className="text-[13px] font-semibold">AI-отчёт за неделю</div>
              <div className="text-[11px] text-txt-2 mt-[2px]">Паттерны и советы от AI</div>
            </div>
            <button
              onClick={handleWeeklyReport}
              disabled={loadingReport}
              className="px-[14px] py-[8px] bg-green text-white rounded-[10px] text-[12.5px] font-semibold border-none cursor-pointer active:opacity-80 disabled:opacity-50 flex-shrink-0"
            >
              {loadingReport ? '⏳' : 'Получить'}
            </button>
          </div>

          {/* Weekly report result */}
          {weeklyReport && (
            <div className="p-[14px] bg-green-xs rounded-[12px] border-l-[3px] border-green page-enter">
              <div className="text-[11px] text-green font-semibold mb-[7px]">✦ AI-отчёт за неделю</div>
              <p className="text-[13px] leading-[1.65] text-txt">{weeklyReport}</p>
            </div>
          )}

          {/* Monthly PDF */}
          <div className="flex items-center justify-between p-[12px] bg-bg-2 rounded-[12px]">
            <div>
              <div className="text-[13px] font-semibold">PDF-отчёт за месяц</div>
              <div className="text-[11px] text-txt-2 mt-[2px]">Таблицы, топ привычек, статистика</div>
            </div>
            <button
              onClick={() => userId && window.open(api.reports.monthlyPdf(userId), '_blank')}
              className="px-[14px] py-[8px] bg-bg-3 text-txt rounded-[10px] text-[12.5px] font-semibold border-none cursor-pointer active:opacity-80 flex-shrink-0"
            >
              Скачать
            </button>
          </div>
        </div>
      </Card>

      {/* Referral */}
      <div className="rounded-card p-[18px] mb-[11px]"
        style={{ background: 'linear-gradient(135deg,#f5f3ed 0%,#e8f0e3 100%)', border: '1.5px solid #d4e8da' }}>
        <div className="text-[10px] uppercase tracking-[1px] text-sage font-semibold mb-[6px]">🔗 Реферальная программа</div>
        <div className="font-serif text-[26px] font-bold text-green-dark text-center tracking-[3px] my-[10px]">
          {ref?.referral_code ?? '——'}
        </div>
        <p className="text-[12px] text-txt-2 text-center mb-[12px]">3 реферала = 1 месяц Pro бесплатно 🎁</p>
        <div className="grid grid-cols-2 gap-[8px] mb-[12px]">
          {[
            { val: ref?.invited_count ?? 0, label: 'приглашено' },
            { val: ref?.next_bonus_at ?? 3, label: 'до бонуса' },
          ].map(({ val, label }) => (
            <div key={label} className="text-center bg-card rounded-[10px] p-[10px]">
              <div className="font-serif text-[20px] font-bold text-green-dark">{val}</div>
              <div className="text-[11px] text-txt-2">{label}</div>
            </div>
          ))}
        </div>
        <Btn onClick={handleCopyRef}>📋 Скопировать реф-ссылку</Btn>
      </div>

      {/* Settings */}
      <Card>
        <CardTitle>⚙️ Настройки</CardTitle>
        <div className="flex flex-col gap-[2px]">
          {[
            { label: 'Утреннее напоминание', sub: 'Ежедневно в 9:00' },
            { label: 'Вечерний чек-ин', sub: 'Ежедневно в 21:00' },
            { label: 'Недельный AI-отчёт', sub: 'Воскресенье в 10:00' },
          ].map(({ label, sub }) => (
            <div key={label} className="flex items-center justify-between py-[12px] border-b border-bg-2 last:border-0">
              <div>
                <div className="text-[13px] font-medium">{label}</div>
                <div className="text-[11px] text-txt-2">{sub}</div>
              </div>
              <div className="w-[44px] h-[24px] rounded-full bg-green relative cursor-pointer flex-shrink-0">
                <div className="w-[20px] h-[20px] rounded-full bg-white absolute top-[2px] right-[2px] shadow-sm" />
              </div>
            </div>
          ))}
          <div className="pt-[12px]">
            <Btn variant="danger" onClick={() => {
              if (confirm('Сбросить все данные приложения? Данные на сервере сохранятся.')) {
                showToast('✓ Локальные данные сброшены')
              }
            }}>
              🗑 Сбросить данные приложения
            </Btn>
          </div>
        </div>
      </Card>

      <div className="h-2" />
    </div>
  )
}
